generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id                String       @id @default(cuid())
  clerkOrgId        String       @unique
  name              String
  githubAccessToken String?
  githubLogin       String?
  createdAt         DateTime     @default(now())
  repos             Repository[]
  members           Member[]
  slackConfig       SlackConfig?
  goals             TeamGoal?
  jiraConfig        JiraConfig?
  invites           Invite[]
}

model Member {
  id          String       @id @default(cuid())
  clerkUserId String
  orgId       String
  role        String       @default("member")  // "owner" | "admin" | "member"
  name        String?
  email       String?
  createdAt   DateTime     @default(now())
  org         Organization @relation(fields: [orgId], references: [id])

  @@unique([clerkUserId, orgId])
  @@index([orgId])
}

model Invite {
  id        String   @id @default(cuid())
  orgId     String
  email     String
  role      String   @default("member")
  token     String   @unique @default(cuid())
  accepted  Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())
  org       Organization @relation(fields: [orgId], references: [id])

  @@index([orgId])
  @@index([token])
}

model Repository {
  id           String        @id @default(cuid())
  githubId     Int           @unique
  name         String
  fullName     String
  orgId        String
  lastSyncedAt DateTime?
  createdAt    DateTime      @default(now())
  org          Organization  @relation(fields: [orgId], references: [id])
  pullRequests PullRequest[]
  deployments  Deployment[]
}

model PullRequest {
  id             String              @id @default(cuid())
  githubPrId     Int
  repoId         String
  title          String
  authorLogin    String
  state          String
  createdAt      DateTime
  firstReviewAt  DateTime?
  approvedAt     DateTime?
  mergedAt       DateTime?
  closedAt       DateTime?
  additions      Int                 @default(0)
  deletions      Int                 @default(0)
  changedFiles   Int                 @default(0)
  commitCount    Int                 @default(0)
  reviewCount    Int                 @default(0)
  cycleTimeHrs   Float?
  codingTimeHrs  Float?
  reviewWaitHrs  Float?
  reviewTimeHrs  Float?
  mergeDelayHrs  Float?
  repo           Repository          @relation(fields: [repoId], references: [id])
  reviews        PullRequestReview[]

  @@unique([repoId, githubPrId])
  @@index([repoId])
  @@index([mergedAt])
  @@index([authorLogin])
  @@index([createdAt])
}

model PullRequestReview {
  id            String      @id @default(cuid())
  prId          String
  reviewerLogin String
  state         String
  submittedAt   DateTime
  pr            PullRequest @relation(fields: [prId], references: [id])

  @@unique([prId, reviewerLogin, submittedAt])
  @@index([prId])
  @@index([reviewerLogin])
}

model Deployment {
  id              String     @id @default(cuid())
  repoId          String
  githubReleaseId Int
  environment     String
  status          String
  deployedAt      DateTime
  createdAt       DateTime   @default(now())
  repo            Repository @relation(fields: [repoId], references: [id])

  @@unique([repoId, githubReleaseId])
  @@index([repoId])
  @@index([deployedAt])
  @@index([status])
}


model SyncJob {
  id        String    @id @default(cuid())
  orgId     String
  status    String    @default("pending")
  startedAt DateTime?
  doneAt    DateTime?
  error     String?
  createdAt DateTime  @default(now())

  @@index([orgId])
  @@index([status])
}

model MetricsSnapshot {
  id                  String   @id @default(cuid())
  orgId               String
  repoId              String?
  period              String
  periodStart         DateTime
  deployFrequency     Float?
  leadTime            Float?
  changeFailureRate   Float?
  mttr                Float?
  totalPRs            Int      @default(0)
  totalDeploys        Int      @default(0)
  avgCycleTime        Float?
  avgCodingTime       Float?
  avgReviewWaitTime   Float?
  avgReviewTime       Float?
  avgMergeDelay       Float?
  createdAt           DateTime @default(now())

  @@unique([orgId, period, periodStart])
  @@index([orgId])
  @@index([periodStart])
}

model SlackConfig {
  id        String   @id @default(cuid())
  orgId     String   @unique
  botToken  String
  channel   String
  events    String[] // e.g. ["pr_merged","cycle_time_exceeded","daily_digest"]
  createdAt DateTime @default(now())
  org       Organization @relation(fields: [orgId], references: [id])
}

model TeamGoal {
  id                  String       @id @default(cuid())
  orgId               String
  deployFrequency     Float?       // target deploys/week
  leadTime            Float?       // target hrs
  changeFailureRate   Float?       // target %
  mttr                Float?       // target hrs
  avgCycleTime        Float?       // target hrs
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  org                 Organization @relation(fields: [orgId], references: [id])

  @@unique([orgId])
}

model JiraConfig {
  id           String       @id @default(cuid())
  orgId        String       @unique
  accessToken  String
  refreshToken String
  cloudId      String
  siteUrl      String
  createdAt    DateTime     @default(now())
  org          Organization @relation(fields: [orgId], references: [id])
}

model JiraIssue {
  id          String   @id @default(cuid())
  orgId       String
  jiraKey     String   @unique  // e.g. "ENG-123"
  summary     String
  status      String
  issueType   String
  assignee    String?
  createdAt   DateTime
  resolvedAt  DateTime?
  prIds       String[] // linked PullRequest ids
}